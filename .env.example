# Xray Server Configuration
# Copy this file to .env and modify with your actual values

# Domain name for SSL certificate
DOMAIN=example.com

# Email for certificate renewal notifications
LETSENCRYPT_EMAIL=admin@example.com

# Xray UUIDs for each inbound (generate new ones with: uuidgen or online tools)
UUID_PORT_80=12345678-1234-1234-1234-123456789012
UUID_PORT_8080=87654321-4321-4321-4321-210987654321
UUID_PORT_8443=11111111-2222-3333-4444-555555555555
UUID_PORT_443=99999999-8888-7777-6666-555555555555

# WebSocket paths
WS_PATH_80=/ws
WS_PATH_8080=/ws8080
WS_PATH_8443=/ws8443
WS_PATH_443=/ws443

# Log level (debug, info, warning, error)
LOG_LEVEL=info

# Timezone
TZ=UTC

# Cert paths
CERT_FILE=/certs/cert.pem
KEY_FILE=/certs/key.pem
